# ===== 服务配置 =====
NODE_PORT=3003
NODE_ENV=development

# ===== WhatsApp 客户端配置 =====
# Headless 模式 (true=无界面, false=显示浏览器)
WA_HEADLESS=false
# 认证数据存储路径
WA_AUTH_PATH=./.wwebjs_auth_v2
# 连接超时 (毫秒)
WA_TIMEOUT=120000

# ===== Puppeteer 浏览器配置 =====
# 浏览器窗口大小
WA_WINDOW_WIDTH=1920
WA_WINDOW_HEIGHT=1080
# 浏览器语言
WA_BROWSER_LANG=en-US,en

# ===== 广播消息配置 =====
# 默认发送间隔 (毫秒)
BROADCAST_DEFAULT_INTERVAL=10000
# 随机化间隔
BROADCAST_RANDOM_INTERVAL=true
# 尊重活跃时间
BROADCAST_RESPECT_HOURS=true
# 随机暂停
BROADCAST_RANDOM_PAUSE=true
# 排除群组
BROADCAST_EXCLUDE_GROUPS=true

# ===== 速率限制配置 =====
# 新账户日限额
RATE_NEW_DAILY=30
RATE_NEW_HOURLY=5
RATE_NEW_MIN_INTERVAL=60000
RATE_NEW_BATCH_SIZE=5
RATE_NEW_BATCH_PAUSE=180000

# 成熟账户日限额
RATE_ESTABLISHED_DAILY=80
RATE_ESTABLISHED_HOURLY=10
RATE_ESTABLISHED_MIN_INTERVAL=30000
RATE_ESTABLISHED_BATCH_SIZE=10
RATE_ESTABLISHED_BATCH_PAUSE=120000

# 老账户日限额
RATE_MATURE_DAILY=150
RATE_MATURE_HOURLY=20
RATE_MATURE_MIN_INTERVAL=20000
RATE_MATURE_BATCH_SIZE=15
RATE_MATURE_BATCH_PAUSE=60000

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ===== 数据库配置 =====
DB_PATH=./data/bot.db